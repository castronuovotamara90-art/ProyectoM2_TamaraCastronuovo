{
  "name": "blog-api",
  "version": "1.0.0",
  "description": "API REST para blog con Express y PostgreSQL",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:init": "node src/db/initDb.js",
    "db:clean-tests": "node src/db/cleanTestData.js",
    "db:clean-tests:preview": "node src/db/cleanTestData.js --dry-run",
    "test": "vitest run --config tests/vitest.config.js",
    "test:watch": "vitest --config tests/vitest.config.js"
  },
  "keywords": [
    "express",
    "postgresql",
    "api",
    "blog"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "supertest": "^7.2.2",
    "vitest": "^4.1.10"
  }
}
